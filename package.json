{
  "name": "typedoc-hybrid-source-links",
  "version": "1.0.1",
  "description": "Hybrid TypeDoc source-link toolkit for local VS Code links, GitHub blob links, AI-agent TypeDoc JSON, and Codex-compatible documentation workflows.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "typedoc-hybrid-install": "./bin/install.mjs"
  },
  "scripts": {
    "install:toolkit": "node bin/install.mjs",
    "smoke": "node bin/smoke-test.mjs"
  },
  "keywords": [
    "typedoc",
    "sourceLinkTemplate",
    "typescript",
    "api-documentation",
    "codex",
    "agents-md",
    "ai-coding-agent",
    "claude-code",
    "cursor",
    "cline",
    "github-pages",
    "developer-tools"
  ],
  "files": [
    "bin",
    "templates",
    "README.md",
    "LICENSE",
    "docs",
    "benchmark.json",
    "AGENTS.template.md",
    "README_SECTION.template.md",
    "HEALTH_REPORT.md"
  ],
  "author": "xraisen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xraisen/typedoc-hybrid-source-links.git"
  },
  "bugs": {
    "url": "git+https://github.com/xraisen/typedoc-hybrid-source-links/issues"
  },
  "homepage": "git+https://github.com/xraisen/typedoc-hybrid-source-links#readme",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "typedoc": ">=0.25.0"
  },
  "peerDependenciesMeta": {
    "typedoc": {
      "optional": false
    }
  }
}
