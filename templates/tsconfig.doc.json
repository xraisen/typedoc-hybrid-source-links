{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "jsx": "react-jsx",
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": []
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "bin/**/*",
    "mcp/**/*",
    "templates/**/*",
    "types/typedoc-local-shims.d.ts",
    "vite-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "docs/api",
    "docs/api-local",
    "docs/api-github",
    "public/docs",
    ".ai/code-graph",
    "**/*.test.*",
    "**/*.spec.*"
  ]
}
