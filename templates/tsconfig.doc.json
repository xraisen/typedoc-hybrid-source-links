{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": []
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "mcp/**/*",
    "bin/**/*",
    "types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "out",
    "output",
    "coverage",
    "docs/api*",
    "public/docs"
  ]
}
