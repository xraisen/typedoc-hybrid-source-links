{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "api/**/*.ts",
    "api/**/*.tsx",
    "api/**/*.mts",
    "api/**/*.mjs",
    "api/**/*.js",
    "scripts/**/*.ts",
    "scripts/**/*.mts",
    "scripts/**/*.mjs",
    "scripts/**/*.js",
    "mcp/**/*.ts",
    "mcp/**/*.mts",
    "mcp/**/*.mjs",
    "mcp/**/*.js",
    "bin/**/*.ts",
    "bin/**/*.mts",
    "bin/**/*.mjs",
    "bin/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "out",
    "output",
    "coverage",
    "docs/api*",
    "public/docs",
    ".ai",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
