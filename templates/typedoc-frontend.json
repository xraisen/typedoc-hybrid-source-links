{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src"
  ],
  "entryPointStrategy": "expand",
  "skipErrorChecking": true,
  "cleanOutputDir": true,
  "validation": {
    "invalidLink": false,
    "notExported": false
  },
  "excludeNotDocumented": false,
  "out": "docs/api-frontend",
  "name": "Project Frontend API Documentation",
  "includeVersion": true,
  "readme": "README.md",
  "tsconfig": "tsconfig.doc.json",
  "excludeNotDocumentedKinds": [
    "Property",
    "Enum"
  ],
  "excludeExternals": true,
  "exclude": [
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/node_modules/**",
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "docs/**",
    "public/docs/**",
    ".ai/code-graph/**"
  ],
  "disableSources": false,
  "sourceLinkTemplate": "{path}#L{line}",
  "sidebarLinks": {
    "Documentation": "/docs/",
    "Frontend API": "/docs/api-frontend/"
  }
}
